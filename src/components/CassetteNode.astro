---
import { Wifi } from "lucide-react";

const { color = "bg-pink-500", label = "TX-01" } = Astro.props;
---

<div class={`relative w-48 h-32 border-4 border-black rounded-md shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-between p-2 overflow-hidden ${color}`}>
  <div class="flex justify-between items-center border-b-2 border-black/20 pb-1">
    <span class="font-mono text-xs font-bold text-black uppercase">{label}</span>
    <div class="flex gap-1">
      <div class="w-2 h-2 rounded-full bg-black animate-pulse"></div>
      <div class="w-2 h-2 rounded-full bg-white"></div>
    </div>
  </div>
  <div class="flex justify-center items-center gap-6 py-2">
    <div class="w-10 h-10 bg-white border-2 border-black rounded-full flex items-center justify-center">
      <div class="w-3 h-3 bg-black rounded-full"></div>
    </div>
    <div class="w-10 h-10 bg-white border-2 border-black rounded-full flex items-center justify-center">
      <div class="w-3 h-3 bg-black rounded-full"></div>
    </div>
  </div>
  <div class="flex justify-between items-end">
    <div class="w-16 h-3 bg-black/20 rounded-full"></div>
    <div class="w-8 h-8 border-2 border-black rounded-full flex items-center justify-center bg-white">
      <Wifi size={14} className="text-black" />
    </div>
  </div>
</div>
